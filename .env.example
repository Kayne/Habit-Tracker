# ==========================================================
# Przykładowa konfiguracja środowiska.
# Skopiuj do .env i UZUPEŁNIJ WARTOŚCI LOKALNIE.
# Plik .env NIGDY nie jest commitowany (patrz .gitignore).
# ==========================================================

# --- PostgreSQL ---
POSTGRES_USER=habit_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=habitdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- JWT (WSPÓLNY sekret między auth-service a habits-service) ---
# Wygeneruj losowy klucz: `openssl rand -hex 32`
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Auth service ---
AUTH_SERVICE_PORT=8001
AUTH_DB_SCHEMA=auth_schema

# --- Habits service ---
HABITS_SERVICE_PORT=8002
HABITS_DB_SCHEMA=habits_schema

# URL auth-service widziany z habits-service (sieć docker-compose)
AUTH_SERVICE_URL=http://auth-service:8001
